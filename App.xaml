<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:DulceRecetario"
             xmlns:helpers="clr-namespace:DulceRecetario.Helpers"
             x:Class="DulceRecetario.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <helpers:BoolToHeartConverter x:Key="BoolToHeartConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
