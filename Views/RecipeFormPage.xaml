<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DulceRecetario.Views.RecipeFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DulceRecetario.ViewModels"
    xmlns:dto="clr-namespace:DulceRecetario.DTOs"
    xmlns:helpers="clr-namespace:DulceRecetario.Helpers"
    x:DataType="vm:RecipeFormViewModel"
    Title="{Binding FormTitle}"
    BackgroundColor="White">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Cancelar" Command="{Binding CancelCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- Sección de Selección de Imagen (Reemplaza Header Banner) -->
            <Grid HeightRequest="220" BackgroundColor="{StaticResource PageBackground}">
                <!-- Overlay con degradado para legibilidad (Posicionado antes del contenido) -->
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0.5" />
                        <GradientStop Color="#99000000" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- Imagen de fondo / Placeholder -->
                <Image 
                    Source="{Binding SelectedImageSource, TargetNullValue='dotnet_bot.png'}" 
                    Aspect="AspectFill">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding SelectedImageSource, Converter={StaticResource IsNullConverter}}" Value="True">
                            <Setter Property="Opacity" Value="0.5" />
                        </DataTrigger>
                        <DataTrigger TargetType="Image" Binding="{Binding SelectedImageSource, Converter={StaticResource IsNotNullConverter}}" Value="True">
                            <Setter Property="Opacity" Value="1.0" />
                        </DataTrigger>
                    </Image.Triggers>
                </Image>

                <!-- Botones de Acción -->
                <HorizontalStackLayout VerticalOptions="End" HorizontalOptions="Center" Spacing="15" Margin="0,0,0,20">
                    <Button 
                        Text="📷 Cámara" 
                        Command="{Binding TakePhotoCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        HeightRequest="40" 
                        Padding="15,0" />
                    <Button 
                        Text="🖼 Galería" 
                        Command="{Binding SelectImageCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        HeightRequest="40" 
                        Padding="15,0" />
                </HorizontalStackLayout>

                <!-- Label Indicador si no hay imagen -->
                <Label 
                    Text="Toca para añadir una foto" 
                    TextColor="White" 
                    FontSize="12" 
                    HorizontalOptions="Center" 
                    VerticalOptions="End" 
                    Margin="0,0,0,5"
                    IsVisible="{Binding SelectedImageSource, Converter={StaticResource IsNullConverter}}" />
            </Grid>

            <VerticalStackLayout Spacing="24" Padding="20" Margin="0,-20,0,0">
                
                <!-- 1. Información Básica -->
                <Frame Padding="20" CornerRadius="24" BackgroundColor="White" HasShadow="True" BorderColor="Transparent">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Información Básica" TextColor="{StaticResource Bordeaux}" FontSize="18" FontAttributes="Bold" />
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Nombre de la receta" Style="{StaticResource LabelCaption}" />
                            <Frame Padding="16,0" HasShadow="False" BorderColor="{StaticResource PrimaryLighter}" BackgroundColor="{StaticResource PageBackground}" CornerRadius="20">
                                <Entry Placeholder="Ej: Red Velvet Special" Text="{Binding Name}" TextColor="Black" HeightRequest="50" />
                            </Frame>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="Categoría" Style="{StaticResource LabelCaption}" />
                                <Frame Padding="12,0" HasShadow="False" BorderColor="{StaticResource PrimaryLighter}" BackgroundColor="{StaticResource PageBackground}" CornerRadius="20">
                                    <Picker ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}" TextColor="Black" HeightRequest="50" />
                                </Frame>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="8">
                                <Label Text="Dificultad" Style="{StaticResource LabelCaption}" />
                                <Frame Padding="12,0" HasShadow="False" BorderColor="{StaticResource PrimaryLighter}" BackgroundColor="{StaticResource PageBackground}" CornerRadius="20">
                                    <Picker ItemsSource="{Binding DifficultyLevels}" SelectedItem="{Binding Difficulty}" TextColor="Black" HeightRequest="50" />
                                </Frame>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- 2. Configuración de Molde (HU-001) -->
                <Frame Padding="20" CornerRadius="24" BackgroundColor="{StaticResource PrimaryLighter}" HasShadow="False" BorderColor="{StaticResource PrimaryLight}">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📏" FontSize="20" VerticalOptions="Center" />
                            <Label Text="Configuración del Molde Base" TextColor="{StaticResource Bordeaux}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Text="Define el tamaño del molde circular para el que fue diseñada la receta original para permitir el escalado automático." FontSize="12" TextColor="{StaticResource Gray600}" />
                        
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                            <Frame Grid.Column="0" Padding="16,0" HasShadow="False" BorderColor="Transparent" BackgroundColor="White" CornerRadius="20">
                                <Entry Placeholder="20" Text="{Binding BaseMoldSize}" Keyboard="Numeric" TextColor="Black" HeightRequest="50" HorizontalTextAlignment="Center" />
                            </Frame>
                            <Label Grid.Column="1" Text="cm (Diámetro)" VerticalOptions="Center" TextColor="{StaticResource Bordeaux}" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- 3. Ingredientes Dinámicos -->
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Ingredientes" TextColor="{StaticResource Bordeaux}" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
                        <Button Grid.Column="1" 
                                Text="+ Añadir" 
                                Command="{Binding AddIngredientCommand}"
                                BackgroundColor="{StaticResource Primary}" 
                                TextColor="White" 
                                CornerRadius="12" 
                                HeightRequest="38" 
                                Padding="12,0"
                                FontSize="13" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Ingredients}" Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="dto:IngredientDto">
                                <Frame Padding="2" CornerRadius="18" BackgroundColor="White" HasShadow="False" BorderColor="{StaticResource PrimaryLighter}">
                                    <Grid ColumnDefinitions="*, 180" HeightRequest="54">
                                        <!-- Nombre del Ingrediente -->
                                        <Entry Grid.Column="0" 
                                               Placeholder="Ej: Harina" 
                                               Text="{Binding Name}" 
                                               FontSize="15" 
                                               TextColor="Black" 
                                               Margin="12,0"
                                               VerticalOptions="Center" />
                                        
                                        <!-- Medida (Cantidad + Unidad) -->
                                        <Frame Grid.Column="1" 
                                               Padding="8,0" 
                                               CornerRadius="16" 
                                               BackgroundColor="{StaticResource PageBackground}" 
                                               HasShadow="False" 
                                               BorderColor="Transparent" 
                                               Margin="2">
                                            <Grid ColumnDefinitions="60, *, 36" ColumnSpacing="4">
                                                <!-- Cantidad (Soporta Fracciones) -->
                                                <Entry Grid.Column="0" 
                                                       Placeholder="0" 
                                                       Text="{Binding QuantityText}" 
                                                       Keyboard="Default" 
                                                       FontSize="14" 
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Bordeaux}" 
                                                       HorizontalTextAlignment="Center" 
                                                       VerticalOptions="Center" />
                                                
                                                <!-- Unidad (Visible y Clara) -->
                                                <Picker Grid.Column="1" 
                                                        ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeFormViewModel}}, Path=Units}" 
                                                        SelectedItem="{Binding Unit}" 
                                                        FontSize="12" 
                                                        TextColor="Black" 
                                                        Title="Uni."
                                                        HorizontalTextAlignment="Center"
                                                        VerticalOptions="Center" />

                                                <!-- Eliminar -->
                                                <ImageButton Grid.Column="2" 
                                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeFormViewModel}}, Path=RemoveIngredientCommand}"
                                                             CommandParameter="{Binding .}"
                                                             BackgroundColor="Transparent"
                                                             Padding="4"
                                                             VerticalOptions="Center">
                                                    <ImageButton.Source>
                                                        <FontImageSource Glyph="✕" Color="{StaticResource Gray400}" Size="18" />
                                                    </ImageButton.Source>
                                                </ImageButton>
                                            </Grid>
                                        </Frame>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- 4. Pasos de Preparación (HU-001) -->
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Preparación" TextColor="{StaticResource Bordeaux}" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
                        <Button Grid.Column="1" 
                                Text="+ Añadir Paso" 
                                Command="{Binding AddStepCommand}"
                                BackgroundColor="{StaticResource Primary}" 
                                TextColor="White" 
                                CornerRadius="12" 
                                HeightRequest="38" 
                                Padding="12,0"
                                FontSize="13" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Steps}" Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="dto:RecipeStepDto">
                                <Frame Padding="12" CornerRadius="18" BackgroundColor="White" HasShadow="False" BorderColor="{StaticResource PrimaryLighter}">
                                    <Grid ColumnDefinitions="32, *, 36" ColumnSpacing="12">
                                        <!-- Número de Paso -->
                                        <Frame Grid.Column="0" HeightRequest="28" WidthRequest="28" CornerRadius="14" Padding="0" BackgroundColor="{StaticResource PrimaryLighter}" HasShadow="False" VerticalOptions="Start" Margin="0,4,0,0">
                                            <Label Text="{Binding Order}" TextColor="{StaticResource Primary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Frame>
                                        
                                        <!-- Descripción del Paso -->
                                        <Editor Grid.Column="1" 
                                                Placeholder="Paso de la preparación..." 
                                                Text="{Binding Description}" 
                                                AutoSize="TextChanges" 
                                                TextColor="Black" 
                                                FontSize="15" 
                                                MinimumHeightRequest="60" />

                                        <!-- Eliminar -->
                                        <ImageButton Grid.Column="2" 
                                                     Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeFormViewModel}}, Path=RemoveStepCommand}"
                                                     CommandParameter="{Binding .}"
                                                     BackgroundColor="Transparent"
                                                     Padding="4"
                                                     VerticalOptions="Start"
                                                     Margin="0,4,0,0">
                                            <ImageButton.Source>
                                                <FontImageSource Glyph="✕" Color="{StaticResource Gray400}" Size="18" />
                                            </ImageButton.Source>
                                        </ImageButton>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- 5. Notas Adicionales -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Descripción o Notas" Style="{StaticResource LabelCaption}" />
                    <Frame Padding="16,8" HasShadow="False" BorderColor="{StaticResource PrimaryLighter}" BackgroundColor="{StaticResource PageBackground}" CornerRadius="20">
                        <Editor Placeholder="Notas especiales sobre la receta..." Text="{Binding Description}" AutoSize="TextChanges" MinimumHeightRequest="80" TextColor="Black" />
                    </Frame>
                </VerticalStackLayout>

                <!-- Botón de Acción Principal -->
                <Button
                    Text="Guardar Obra Maestra"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    HeightRequest="60"
                    FontSize="20"
                    Margin="0,10,0,40" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
