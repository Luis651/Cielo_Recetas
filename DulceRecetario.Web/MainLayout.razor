@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation
@using DulceRecetario.Shared.Services
@using Microsoft.AspNetCore.Components.Authorization

<div class="page-container">
    <div class="top-bar py-3 px-4 d-flex justify-content-between align-items-center">
        <h1 class="brand-title m-0" style="cursor: pointer;" @onclick='() => Navigation.NavigateTo("/")'>Cielo Recetas 🍓</h1>

        <AuthorizeView>
            <Authorized>
                <div class="user-menu">
                    <span class="user-email">@context.User.Identity?.Name</span>
                    <button class="btn-logout" @onclick="HandleLogout" title="Cerrar sesión">
                        Salir 👋
                    </button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    <main class="main-content">
        @Body
    </main>

    <footer class="text-center py-5 opacity-50 small">
        &copy; 2026 Cielo Recetas • Creado con ❤️ para reposteros
    </footer>
</div>

<style>
    .page-container {
        max-width: 1400px;
        margin: 0 auto;
    }
    .main-content {
        padding: 2rem 1rem;
    }
    @@media (min-width: 768px) {
        .main-content { padding: 3rem 2rem; }
    }

    .user-menu {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .user-email {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-muted);
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .btn-logout {
        background: var(--primary-lighter);
        color: var(--accent);
        border: none;
        border-radius: 14px;
        padding: 7px 16px;
        font-size: 0.82rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.25s;
        white-space: nowrap;
    }
    .btn-logout:hover {
        background: var(--accent);
        color: white;
    }
    @@media (max-width: 400px) {
        .user-email { display: none; }
    }
</style>

@code {
    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }
}
