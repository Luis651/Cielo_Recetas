@page "/"
@attribute [Authorize]
@inject RecipeService RecipeService
@inject NavigationManager Navigation

<PageTitle>Cielo Recetas 🍓</PageTitle>

<div class="search-section mb-5 animate__animated animate__fadeIn">
    <div class="search-bar-wrapper">
        <i class="search-icon">🔍</i>
        <input type="text" class="search-input" placeholder="¿Qué delicia hornearemos hoy?" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
    </div>
</div>

@if (recipes == null)
{
    <div class="loading-state py-5 text-center">
        <div class="strawberry-loader mt-4">🍓</div>
        <p class="mt-4 fw-bold text-primary">Preparando el cielo dulce...</p>
    </div>
}
else if (!recipes.Any())
{
    <div class="empty-state text-center py-5 glass-card mx-auto" style="max-width: 500px;">
        <h3 class="fw-bold mb-3">¡Aún no hay recetas! 🧁</h3>
        <p class="text-muted">El recetario está esperando tu primer secreto de repostería.</p>
        <button class="btn btn-premium mt-3" @onclick='() => Navigation.NavigateTo("add")'>Crear mi primera receta</button>
    </div>
}
else
{
    <div class="container-fluid p-0">
        <h4 class="section-label mb-4">Nuestras Creaciones</h4>
        <div class="row g-4">
            @foreach (var recipe in recipes)
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3 animate__animated animate__zoomIn">
                    <div class="recipe-card" @onclick="() => NavigateToDetail(recipe.Id)">
                        <div class="recipe-image-container">
                            <span class="recipe-category-tag">@recipe.Category</span>
                            <img src="@(string.IsNullOrEmpty(recipe.ImageUrl) ? "icon-512.png" : recipe.ImageUrl)" class="recipe-image" loading="lazy" />
                            <div class="image-grad"></div>
                        </div>
                        <div class="recipe-info">
                            <h3 class="recipe-name">@recipe.Name</h3>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<a href="add" class="fab shadow-lg" title="Añadir Receta">+</a>

<style>
    .search-bar-wrapper {
        position: relative;
        max-width: 600px;
        margin: 0 auto;
    }
    .search-input {
        width: 100%;
        padding: 18px 25px 18px 60px;
        border-radius: 25px;
        border: none;
        background: white;
        box-shadow: var(--shadow-md);
        font-size: 1.1rem;
        transition: all 0.3s;
    }
    .search-input:focus {
        outline: none;
        box-shadow: var(--shadow-lg);
        transform: scale(1.02);
    }
    .search-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.4rem;
        opacity: 0.5;
    }
    .section-label {
        font-weight: 800;
        color: var(--bordeaux);
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.9rem;
        opacity: 0.7;
    }
    .strawberry-loader {
        font-size: 4rem;
        animation: pulse 2s infinite;
        display: inline-block;
    }
    @@keyframes pulse {
        0% { transform: scale(1); filter: drop-shadow(0 0 0 rgba(255,77,109,0)); }
        50% { transform: scale(1.1); filter: drop-shadow(0 10px 20px rgba(255,77,109,0.3)); }
        100% { transform: scale(1); filter: drop-shadow(0 0 0 rgba(255,77,109,0)); }
    }
    .image-grad {
        position: absolute;
        bottom: 0; left: 0; right: 0; height: 50%;
        background: linear-gradient(0deg, rgba(128,15,47,0.1) 0%, transparent 100%);
    }
    .dot { font-weight: bold; color: var(--primary); }

    /* Tarjetas del home — más espacio vertical para que respiren */
    .recipe-info {
        padding: 24px 22px 28px;
    }
    .recipe-name {
        font-size: 1.15rem;
        line-height: 1.35;
    }
    .recipe-image-container {
        height: 210px;
    }
</style>

@code {
    private List<RecipeDto>? recipes;
    private string searchQuery = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipes();
    }

    private async Task LoadRecipes()
    {
        recipes = await RecipeService.GetAllRecipesAsync();
    }

    private async Task HandleSearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            await LoadRecipes();
        }
        else
        {
            recipes = await RecipeService.SearchRecipesAsync(searchQuery);
        }
    }

    private void NavigateToDetail(Guid id) => Navigation.NavigateTo($"recipe/{id}");
}
