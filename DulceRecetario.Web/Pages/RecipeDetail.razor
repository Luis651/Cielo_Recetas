@page "/recipe/{Id:guid}"
@attribute [Authorize]
@inject RecipeService RecipeService
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (recipe == null)
{
    <div class="text-center py-5">
        <div class="strawberry-loader">🍓</div>
        <p class="mt-3">Buscando el secreto dulce...</p>
    </div>
}
else
{
    <div class="recipe-detail-container animate__animated animate__fadeIn">
        <!-- Hero Section: Clean & Focused -->
        <div class="detail-hero shadow-lg" style="background-image: url('@(string.IsNullOrEmpty(recipe.ImageUrl) ? "icon-512.png" : recipe.ImageUrl)')">
            <div class="detail-overlay">
                <button class="btn-circular-back shadow" @onclick="GoBack" type="button">←</button>
            </div>
        </div>

        <div class="card-overlap">
            <!-- Header Section: Title & Description -->
            <div class="recipe-header mb-5">
                <span class="badge-custom">@(recipe.Category ?? "Otros")</span>
                <h1 class="display-3 fw-bold mt-2 mb-3" style="color: var(--bordeaux);">@recipe.Name</h1>
                @if (!string.IsNullOrEmpty(recipe.Description))
                {
                    <p class="description-text">@recipe.Description</p>
                }
            </div>


            <div class="row g-5">
                <!-- Left: Instructions -->
                <div class="col-lg-7">
                    <h3 class="section-title-premium mb-4"><span>Preparación</span></h3>
                    <div class="steps-timeline">
                        @if (recipe.Steps != null && recipe.Steps.Any())
                        {
                            @foreach (var step in recipe.Steps.OrderBy(s => s.Order))
                            {
                                <div class="step-card mb-4 animate__animated animate__fadeInUp">
                                    <div class="step-header">
                                        <span class="step-num">Paso @step.Order</span>
                                    </div>
                                    <div class="step-body">
                                        @step.Description
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted italic">No hay pasos registrados para esta receta.</p>
                        }
                    </div>
                </div>

                <!-- Right: Ingredients & Tools -->
                <div class="col-lg-5">
                    <div class="sticky-sidebar">
                        <div class="ingredients-card p-5 glass-card mb-4 shadow-sm">
                            <h4 class="fw-bold mb-4" style="color: var(--bordeaux);">Ingredientes ✨</h4>
                            
                            <div class="scaling-tool mb-4 p-3 rounded-4" style="background: var(--primary-lighter);">
                                <label class="small fw-bold mb-2 d-block text-accent">AJUSTAR POR MOLDE: @(recipe.BaseMoldSize) cm</label>
                                <div class="input-group">
                                    <input type="number" class="form-control premium-pill-input w-50" 
                                           @bind="targetMoldSize" @bind:event="oninput" @onkeyup="UpdateScaling" />
                                    <span class="input-group-text bg-transparent border-0 fw-bold">cm</span>
                                </div>
                                <div class="mt-2 small text-muted">Ajuste actual: <strong>x@(scalingFactor.ToString("0.##"))</strong></div>
                            </div>

                            <ul class="ing-list">
                                @if (recipe.Ingredients != null && recipe.Ingredients.Any())
                                {
                                    @foreach (var ing in recipe.Ingredients)
                                    {
                                        <li class="py-3 d-flex align-items-center">
                                            <span class="ing-dot me-3"></span>
                                            <div class="d-flex justify-content-between w-100">
                                                <span class="ing-name">@ing.Name</span>
                                                <span class="ing-amount">@((ing.Quantity * scalingFactor).ToString("0.##")) @ing.Unit</span>
                                            </div>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="text-muted">No hay ingredientes registrados.</li>
                                }
                            </ul>
                        </div>

                        <div class="d-flex justify-content-center gap-3">
                            @if (!isDeleting)
                            {
                                <button class="btn btn-danger-premium" @onclick="() => isDeleting = true" type="button">Eliminar 🗑</button>
                                <button class="btn btn-premium flex-grow-1" @onclick="EditRecipe" type="button">Editar Receta ✍️</button>
                            }
                            else
                            {
                                <div class="confirmation-box animate__animated animate__pulse animate__infinite">
                                    <p class="text-danger small fw-bold mb-2">¿Confirmas el borrado? 🍓</p>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-secondary-premium flex-grow-1" @onclick="() => isDeleting = false">Atrás</button>
                                        <button class="btn btn-danger-premium flex-grow-2" @onclick="DeleteRecipe">BORRAR</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .description-text { font-size: 1.1rem; line-height: 1.7; color: var(--text-muted); }
    
    .step-card { background: white; border-radius: 24px; padding: 25px; border-left: 5px solid var(--primary); box-shadow: var(--shadow-sm); }
    .step-num { font-weight: 800; color: var(--primary); font-size: 0.8rem; text-transform: uppercase; }
    .step-body { margin-top: 10px; font-size: 1.05rem; line-height: 1.6; }
    
    .ing-list { list-style: none; padding: 0; }
    .ing-list li { border-bottom: 1px solid rgba(255, 77, 109, 0.05); }
    .ing-dot { width: 8px; height: 8px; background: var(--primary-light); border-radius: 50%; flex-shrink: 0; }
    .ing-name { font-weight: 500; font-size: 1.05rem; }
    .ing-amount { font-weight: 800; color: var(--accent); }
    
    .sticky-sidebar { position: sticky; top: 100px; }
    
    .scaling-tool .input-group {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        border: 2px solid white;
    }
    .scaling-tool .form-control {
        border: none;
        box-shadow: none;
        text-align: center;
        font-weight: 800;
        color: var(--accent);
    }

    .confirmation-box {
        background: #fff5f6;
        padding: 15px;
        border-radius: 20px;
        border: 2px dashed var(--accent);
        width: 100%;
        text-align: center;
    }
    .flex-grow-2 { flex-grow: 2; }
</style>

@code {
    [Parameter] public Guid Id { get; set; }
    private RecipeDto? recipe;
    private double targetMoldSize;
    private double scalingFactor = 1.0;

    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {
        recipe = await RecipeService.GetRecipeByIdAsync(Id);
        if (recipe != null)
        {
            targetMoldSize = recipe.BaseMoldSize;
            UpdateScaling();
        }
    }

    private void UpdateScaling()
    {
        if (recipe != null && recipe.BaseMoldSize > 0 && targetMoldSize > 0)
        {
            scalingFactor = Math.Pow(targetMoldSize, 2) / Math.Pow(recipe.BaseMoldSize, 2);
        }
        else
        {
            scalingFactor = 1.0;
        }
    }

    private void GoBack() => Navigation.NavigateTo("");
    private void EditRecipe() => Navigation.NavigateTo($"edit/{recipe?.Id}");
    private async Task DeleteRecipe()
    {
        if (recipe == null) return;
        await RecipeService.DeleteRecipeAsync(recipe.Id);
        Navigation.NavigateTo("");
    }
}
